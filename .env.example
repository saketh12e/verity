# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Web Search + Scraping
FIRECRAWL_API_KEY=fc-...

# Vector DB
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=verity-findings
